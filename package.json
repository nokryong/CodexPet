{
  "name": "code-pet",
  "version": "0.1.0",
  "private": true,
  "description": "Codex-linked transparent CodePet overlay for Windows.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "app.codepet.desktop",
    "productName": "CodePet",
    "directories": {
      "output": "artifacts"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "build/icon.ico",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "portable"
      ]
    },
    "portable": {
      "artifactName": "CodePet-${version}.exe"
    }
  },
  "devDependencies": {
    "electron": "^40.10.6",
    "electron-builder": "^26.15.3"
  }
}
