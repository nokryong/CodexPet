{
  "name": "code-pet",
  "version": "0.3.2",
  "private": true,
  "description": "Multi-provider desktop companion for Codex, Antigravity, and Claude.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "test": "node --test",
    "dist": "node scripts/build.js"
  },
  "build": {
    "appId": "app.codepet.desktop",
    "productName": "CodePet",
    "directories": {
      "output": "artifacts"
    },
    "files": [
      "src/**/*",
      "build/icon.ico",
      "build/icon.png",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "portable"
      ]
    },
    "portable": {
      "artifactName": "CodePet-${version}.exe"
    },
    "mac": {
      "icon": "build/icon-mac.png",
      "category": "public.app-category.utilities",
      "target": [
        "dmg",
        "zip"
      ]
    }
  },
  "devDependencies": {
    "electron": "^40.10.6",
    "electron-builder": "^26.15.3"
  }
}
